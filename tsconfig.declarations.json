{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist-types",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false
  },
  "include": ["src/main/**/*.ts", "src/renderer/**/*.tsx", "preload/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/__tests__/**"]
}
